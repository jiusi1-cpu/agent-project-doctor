{
  "name": "agent-project-doctor",
  "version": "0.1.0",
  "description": "Local AI coding agent readiness signal scanner for repositories.",
  "type": "module",
  "bin": {
    "agent-project-doctor": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "examples"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "keywords": [
    "agents",
    "ai-coding",
    "codex",
    "claude-code",
    "cursor",
    "cline",
    "cli",
    "repository"
  ],
  "author": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/jiusi1-cpu/agent-project-doctor.git"
  },
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
